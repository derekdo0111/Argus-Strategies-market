# Tushare Token
TUSHARE_TOKEN=your_tushare_token_here

# LLM API — DeepSeek (OpenAI 兼容)
LLM_API_KEY=your_deepseek_api_key_here
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
LLM_MAX_TOKENS=32768
LLM_TEMPERATURE=0.1

# WebSearch — Bocha (v0.23: 主搜索引擎)
BOCHA_API_KEY=your_bocha_api_key_here

# WebSearch — Tavily (备用)
TAVILY_API_KEY=your_tavily_api_key_here

TURTLE_RISK_FREE_RATE=1.7
TURTLE_SPREAD=1.0

# CORS (开发环境)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 调试模式 (生产环境设为 false)
DEBUG=false

# 高景气策略 — HypothesizeAgent (v0.21)
PROSPERITY_HYPOTHESIZE_ROUNDS=3
PROSPERITY_HYPOTHESIZE_PHASE1_TIMEOUT=25

# 调度
FULL_REFRESH_CRON="0 6 * * 1-5"
